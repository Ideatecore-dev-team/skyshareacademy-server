{
  "name": "msim-server-new",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "dotenv -e .env.dev tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "test": "dotenv -e .env.test vitest",
    "test:coverage": "dotenv -e .env.test -- vitest run --coverage",
    "lint": "biome check src",
    "lint:format": "biome check --write src",
    "generate": "npx prisma generate",
    "migrate": "npx prisma migrate deploy",
    "migrate:dev": "dotenv -e .env.dev -- npx prisma migrate dev",
    "migrate:test": "dotenv -e .env.test -- npx prisma migrate dev",
    "migrate:dev:status": "dotenv -e .env.dev -- npx prisma migrate status",
    "openapi": "swagger-cli bundle docs/main.yml --outfile docs/openapi.yml --type yaml"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ideatecore-dev-team/skyshareacademy-server.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Ideatecore-dev-team/skyshareacademy-server/issues"
  },
  "homepage": "https://github.com/Ideatecore-dev-team/skyshareacademy-server#readme",
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "dotenv-cli": "^8.0.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "yamljs": "^0.3.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/hpp": "^0.2.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34",
    "@vitest/coverage-v8": "^3.2.4",
    "prisma": "^6.10.1",
    "supertest": "^7.1.1",
    "swagger-cli": "^4.0.4",
